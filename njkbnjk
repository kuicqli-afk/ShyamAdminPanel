import { BrowserRouter, Routes, Route, Navigate } from "react-router-dom";
import "./App.css";
import { ToastContainer } from "react-toastify";
import "react-toastify/dist/ReactToastify.css";
import Sidebar from "./Components/Sidebar/Sidebar";
import AddProduct from "./Components/AddProducts/AddProduct";
import Dashboard from "./Components/Dashboard/Dashboard";
import ProductList from "./Components/ProductList/ProductsList";
import AddBanner from "./Components/Addbanner/AddBanner";
import Category from "./Components/Category/Category";
import BannerList from "./Components/Addbanner/BannerList";
import AddOffers from "./Components/Offers/AddOffers";
import LoginPage from "./Components/Login/LoginPage";
import OfferList from "./Components/Offers/OfferList";
import { useState } from "react";

function App() {
  // Track the login state of the user
  const [isLoggedIn, setIsLoggedIn] = useState(false);

  // Protect routes that require login
  const ProtectedRoute = ({ element }) => {
    if (!isLoggedIn) {
      return <Navigate to="/" />; // Redirect to Login if not logged in
    }
    return element;
  };
  

  return (
    <BrowserRouter>
      <ToastContainer />
      <div className="admin-layout">
        {/* Sidebar */}
        {isLoggedIn && <Sidebar />}

        {/* Main Content */}
        <div className="main-content">
          <Routes>
            {/* Public Route */}
            <Route path="/" element={<LoginPage setIsLogin={setIsLoggedIn} />} />

            {/* Protected Routes */}
            <Route path="/dashboard" element={<ProtectedRoute element={<Dashboard />} />} />
            <Route path="/products/add" element={<ProtectedRoute element={<AddProduct />} />} />
            <Route path="/products/list" element={<ProtectedRoute element={<ProductList />} />} />
            <Route path="/add-banner" element={<ProtectedRoute element={<AddBanner />} />} />
            <Route path="/banner-list" element={<ProtectedRoute element={<BannerList />} />} />
            <Route path="/category" element={<ProtectedRoute element={<Category />} />} />
            <Route path="/offers" element={<ProtectedRoute element={<AddOffers />} />} />
            <Route path="/offer-list" element={<ProtectedRoute element={<OfferList />} />} />
          </Routes>
        </div>
      </div>
    </BrowserRouter>
  );
}

export default App;